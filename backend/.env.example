# AgroSeva Environment Variables

# Arduino Moisture Sensor (COM port)
COM_PORT=COM6

# TinyML ESP32 (separate board for disease detection)
TINYML_COM_PORT=COM16

# Groq LLM API Key (get from https://console.groq.com)
# Required for online disease diagnosis
GROQ_API_KEY=your_groq_api_key_here

# Groq model (optional, default: llama-3.3-70b-versatile)
# GROQ_MODEL=llama-3.3-70b-versatile
